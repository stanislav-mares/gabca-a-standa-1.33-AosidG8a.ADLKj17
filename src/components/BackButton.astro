<button
    id="back-btn"
    class="flex w-40 justify-center items-center h-full p-2 text-title font-extralight min-h-screen hover:bg-gray-100 transition-colors cursor-pointer"
    >&lt;</button
>

<script>
    document.addEventListener("astro:page-load", () => {
        const backBtn = document.getElementById("back-btn");
        if (backBtn) {
            backBtn.addEventListener("click", () => {
                history.back();
            });
        }
    });
</script>
