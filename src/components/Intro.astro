---
import ForwardButton from "./ForwardButton.astro";
import CeremonyDate from "./CeremonyDate.astro";
import Logo from "./Logo.astro";
---

<div
    id="intro-overlay"
    class="fixed w-screen h-screen inset-0 z-20 cursor-pointer flex items-center justify-center bg-gradient-to-r from-gray-50 from-50% to-gray-100 to-50%"
>
    <div class="intro-content text-center absolute">
        <Logo width={240} height={240} />
    </div>
    <div class="absolute ml-90 text-center">
        <CeremonyDate />
    </div>
    <div class="absolute right-0 z-25 group w-full h-full">
        <ForwardButton />
    </div>
</div>

<style>
    /* View Transition animace */
    ::view-transition-old(root) {
        animation: intro-fade-out 0.7s ease-out;
    }

    ::view-transition-new(root) {
        animation: content-fade-in 1.5s ease-in-out;
    }

    @keyframes intro-fade-out {
        from {
            opacity: 1;
        }
        to {
            opacity: 0;
        }
    }

    @keyframes content-fade-in {
        from {
            opacity: 0;
        }
        to {
            opacity: 1;
        }
    }
</style>

<script>
    function setupIntro() {
        const introOverlay = document.getElementById("intro-overlay");
        const hasSeenIntro = localStorage.getItem("hasSeenIntro");

        if (!introOverlay) {
            console.error("Intro overlay element not found.");
            return;
        }

        if (hasSeenIntro) {
            introOverlay.remove();
            return;
        }

        // Vždy zobrazuj intro - čekej na kliknutí
        introOverlay.addEventListener("click", () => {
            // Použij View Transition API pokud je dostupné
            if (!document.startViewTransition) {
                // Fallback pro starší prohlížeče
                introOverlay.style.transition = "transform 2s ease-in-out, opacity 0.7s ease-out";
                introOverlay.style.transform = "translateX(-100%)";
                introOverlay.style.opacity = "0";

                setTimeout(() => {
                    introOverlay.remove();
                }, 2000);
                return;
            }

            // View Transition API implementace
            const transition = document.startViewTransition(() => {
                introOverlay.remove();
            });

            localStorage.setItem("hasSeenIntro", "true");
        });
    }

    // // Spusť při načtení
    // setupIntro();

    // Spusť znovu po každé Astro navigaci
    document.addEventListener("astro:page-load", setupIntro);
</script>
