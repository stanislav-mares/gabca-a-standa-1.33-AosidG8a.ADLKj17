---
import ForwardButton from "./ForwardButton.astro";
import Logo from "./Logo.astro";
import { Image } from "astro:assets";
import introBackground from "../assets/dkr-1795-bw.jpg";
---

<div
    id="intro-overlay"
    class="fixed inset-0 z-20 flex items-center bg-surface overflow-hidden"
>
    <!-- Stejný scale/origin jako fotka pozadí v Layout.astro, aby na sebe navazovaly -->
    <Image
        src={introBackground}
        alt=""
        class="absolute inset-0 w-full h-full object-cover scale-130 origin-[0%_50%]"
    />
    <!-- Jemný přechod pro čitelnost loga nad fotkou -->
    <div
        class="absolute inset-0 bg-gradient-to-r from-surface/90 via-surface/40 to-transparent"
    >
    </div>
    <!-- Logo vlevo — zarovnané nad panelem Headeru kvůli plynulému přesunu -->
    <div
        class="relative w-full xl:w-1/2 flex items-center justify-center gap-8"
    >
        <div class="intro-logo">
            <Logo width={480} height={480} />
        </div>
        <ForwardButton />
    </div>
</div>

<style>
    #intro-overlay {
        transition: opacity 1.5s ease-in-out;
    }

    #intro-overlay.intro-leaving {
        opacity: 0;
        pointer-events: none;
    }

    .intro-logo {
        transition: transform 1.5s ease-in-out;
    }
</style>

<script>
    function setupIntro() {
        const introOverlay = document.getElementById("intro-overlay");

        if (!introOverlay) {
            console.error("Intro overlay element not found.");
            return;
        }

        introOverlay.addEventListener("click", () => {
            if (introOverlay.classList.contains("intro-leaving")) return;

            // Změř obě loga a posuň/zmenši intročkové přesně na to v Headeru
            const logoWrap =
                introOverlay.querySelector<HTMLElement>(".intro-logo");
            const introLogo = logoWrap?.querySelector("img");
            const headerPanel = document.getElementById("main-header");
            const headerLogo = headerPanel?.querySelector("img");

            if (logoWrap && introLogo && headerPanel && headerLogo) {
                const from = introLogo.getBoundingClientRect();
                const to = headerLogo.getBoundingClientRect();
                // Header je teď ještě vysunutý o svou šířku vlevo — cílíme na finální pozici
                const panelOffset = headerPanel.getBoundingClientRect().width;
                const dx =
                    to.left +
                    panelOffset +
                    to.width / 2 -
                    (from.left + from.width / 2);
                const dy =
                    to.top + to.height / 2 - (from.top + from.height / 2);
                const scale = to.width / from.width;
                logoWrap.style.transform = `translate(${dx}px, ${dy}px) scale(${scale})`;
            }

            headerPanel?.classList.add("header-entered");

            introOverlay.classList.add("intro-leaving");
            // transitionend bublá i z dětí (např. barevný přechod tlačítka),
            // reagujeme jen na opacity samotného overlaye
            introOverlay.addEventListener("transitionend", (e) => {
                if (e.target === introOverlay && e.propertyName === "opacity") {
                    introOverlay.remove();
                }
            });
        });
    }

    // Spusť znovu po každé Astro navigaci
    document.addEventListener("astro:page-load", setupIntro);
</script>
