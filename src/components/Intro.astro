---
import ForwardButton from "./ForwardButton.astro";
import Logo from "./Logo.astro";
import { Image } from "astro:assets";
import introBackground from "../assets/dkr-1795-bw.jpg";
---

<div
    id="intro-overlay"
    class="fixed inset-0 z-20 flex items-center bg-surface overflow-hidden"
>
    <!-- Stejný scale/origin jako fotka pozadí v Layout.astro, aby na sebe navazovaly -->
    <Image
        src={introBackground}
        alt=""
        class="absolute inset-0 w-full h-full object-cover scale-130 origin-[0%_50%]"
    />
    <!-- Jemný přechod pro čitelnost loga nad fotkou -->
    <div
        class="absolute inset-0 bg-gradient-to-r from-surface/90 via-surface/40 to-transparent"
    >
    </div>
    <!-- Logo vlevo — zarovnané nad panelem Headeru kvůli plynulému přesunu -->
    <div class="relative w-full xl:w-[30%] 2xl:w-[35%] flex justify-center">
        <Logo width={480} height={480} />
    </div>
    <ForwardButton />
</div>

<style>
    /* View Transition animace */
    ::view-transition-old(root) {
        animation: intro-fade-out 0.7s ease-out;
    }

    ::view-transition-new(root) {
        animation: content-fade-in 1.5s ease-in-out;
    }

    @keyframes intro-fade-out {
        from {
            opacity: 1;
        }
        to {
            opacity: 0;
        }
    }

    @keyframes content-fade-in {
        from {
            opacity: 0;
        }
        to {
            opacity: 1;
        }
    }
</style>

<script>
    function setupIntro() {
        const introOverlay = document.getElementById("intro-overlay");

        if (!introOverlay) {
            console.error("Intro overlay element not found.");
            return;
        }

        introOverlay.addEventListener("click", () => {
            if (!document.startViewTransition) {
                // Fallback pro starší prohlížeče
                introOverlay.style.transition =
                    "transform 2s ease-in-out, opacity 0.7s ease-out";
                introOverlay.style.transform = "translateX(-100%)";
                introOverlay.style.opacity = "0";

                setTimeout(() => {
                    introOverlay.remove();
                }, 2000);
                return;
            }

            document.startViewTransition(() => {
                introOverlay.remove();
            });
        });
    }

    // Spusť znovu po každé Astro navigaci
    document.addEventListener("astro:page-load", setupIntro);
</script>
