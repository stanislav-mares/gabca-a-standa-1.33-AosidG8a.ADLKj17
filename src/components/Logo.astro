---
import { Image } from "astro:assets";
import mainLogo from "../assets/logo-test.png";

// 1. (Optional) Define the TypeScript interface for your props
interface Props {
    width: number;
    height: number; // The '?' makes this prop optional
}

// 2. Destructure the properties from Astro.props
const { width = 128, height = 128 } = Astro.props;
---

<div class="flex justify-center">
    <Image
        src={mainLogo}
        alt="Logo"
        width={width}
        height={height}
        class="max-w-full h-auto"
        style={`width: ${width}px`}
    />
</div>
