---
import type { Element } from "../utils/questionnaire";
import Self from "./QuestionElement.astro";

interface Props {
  /** Prvek k vyrenderování. */
  element: Element;
  /** Unikátní základ pro atributy `name`/`id` v rámci formuláře. */
  name: string;
  /**
   * Vynutí povinnost prvku bez ohledu na konfiguraci. Používá se u podotázek –
   * jakmile se follow-up zobrazí, jeho pole musí být vyplněná.
   */
  forceRequired?: boolean;
}

const { element, name, forceRequired = false } = Astro.props;

const required = forceRequired || element.required;

const inputClass =
  "w-full px-4 py-3 bg-transparent border border-gray-300 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 placeholder-gray-400 focus:outline-none focus:border-gray-700 focus:ring-1 focus:ring-gray-700 transition-colors";
const labelClass =
  "block text-lg font-bold text-gray-900 dark:text-gray-100 mb-1";
const descriptionClass =
  "block text-sm text-gray-500 dark:text-gray-500 mb-2";

const isMulti = element.type === "multi-choice";
const isChoice =
  element.type === "yes-no" ||
  element.type === "single-choice" ||
  isMulti;
const options = element.options ?? [];
// Povinnost dává u nativní validace smysl jen pro skupiny přepínačů.
const choiceRequired = required && !isMulti ? true : undefined;
---

{
  element.type === "short-text" && (
    <div>
      <label for={name} class={labelClass} set:html={element.label} />
      {element.description && (
        <p class={descriptionClass} set:html={element.description} />
      )}
      <input
        type="text"
        id={name}
        name={name}
        class={inputClass}
        placeholder={element.placeholder ?? "Zde napište krátkou odpověď..."}
        required={required}
      />
    </div>
  )
}

{
  element.type === "textarea" && (
    <div>
      <label for={name} class={labelClass} set:html={element.label} />
      {element.description && (
        <p class={descriptionClass} set:html={element.description} />
      )}
      <textarea
        id={name}
        name={name}
        rows="4"
        class:list={[inputClass, "resize-y"]}
        placeholder={
          element.placeholder ?? "Prostor pro detailnější odpověď..."
        }
        required={required}
      />
    </div>
  )
}

{
  isChoice && (
    <div>
      <span class={labelClass} set:html={element.label} />
      {element.description && (
        <p class={descriptionClass} set:html={element.description} />
      )}
      <div class="flex flex-col gap-3">
        {options.map((opt) => (
          <div>
            <label class="flex items-center gap-2 cursor-pointer text-gray-900 dark:text-gray-100">
              <input
                type={isMulti ? "checkbox" : "radio"}
                id={`${name}-${opt.value}`}
                name={isMulti ? `${name}-${opt.value}` : name}
                value={opt.value}
                class="size-4 accent-gray-900 dark:accent-gray-100"
                required={choiceRequired}
                data-followup={
                  opt.followUp ? `${name}-${opt.value}-followup` : undefined
                }
              />
              <span set:html={opt.label} />
            </label>

            {opt.followUp && (
              <div
                id={`${name}-${opt.value}-followup`}
                class="follow-up hidden mt-4 ml-6 pl-4 border-l-2 border-gray-200 dark:border-gray-800 flex-col gap-4"
              >
                {opt.followUp.heading && (
                  <p
                    class="text-sm font-medium text-gray-800 dark:text-gray-300"
                    set:html={opt.followUp.heading}
                  />
                )}
                {opt.followUp.elements.map((sub, k) => (
                  <Self
                    element={sub}
                    name={`${name}-${opt.value}-s${k}`}
                    forceRequired
                  />
                ))}
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  )
}
