---
const questions = [
  { id: 'q1', heading: '1. Očekávání a cíle', inputLabel: 'Hlavní cíl projektu', textLabel: 'Detailně popište, čeho chcete dosáhnout' },
  { id: 'q2', heading: '2. Cílová skupina', inputLabel: 'Kdo je váš typický zákazník?', textLabel: 'Specifikujte jejich potřeby a chování' },
  { id: 'q3', heading: '3. Konkurence', inputLabel: 'Kdo je váš největší konkurent?', textLabel: 'V čem se od konkurence chcete odlišit?' },
  { id: 'q4', heading: '4. Vizuální styl', inputLabel: 'Preferujete nějaké barvy?', textLabel: 'Jakou emoci má váš projekt vyvolávat?' },
  { id: 'q5', heading: '5. Funkční požadavky', inputLabel: 'Jaká je absolutně klíčová funkce?', textLabel: 'Vypište všechny další potřebné funkce' },
  { id: 'q6', heading: '6. Harmonogram', inputLabel: 'Kdy má být projekt hotový?', textLabel: 'Jsou v průběhu nějaké fixní milníky?' },
  { id: 'q7', heading: '7. Další informace', inputLabel: 'Máte vyhrazený rozpočet?', textLabel: 'Jaké podklady (texty, fotky) už máte k dispozici?' },
];
---

<div class="max-w-3xl mx-auto p-6 md:p-10">
  <form action="#" method="POST" class="space-y-12">

    {questions.map((q) => (
      <fieldset class="pb-12 border-b border-gray-200 dark:border-gray-800 last:border-0 last:pb-0">
        <legend class="text-xl font-semibold text-gray-900 dark:text-gray-100 mb-6">
          {q.heading}
        </legend>

        <div class="flex flex-col gap-6">
          <div>
            <label for={`input-${q.id}`} class="block text-sm font-medium text-gray-700 dark:text-gray-400 mb-2">
              {q.inputLabel}
            </label>
            <input
              type="text"
              id={`input-${q.id}`}
              name={`input-${q.id}`}
              class="w-full px-4 py-3 bg-transparent border border-gray-300 dark:border-gray-700 rounded-md text-gray-900 dark:text-gray-100 placeholder-gray-400 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition-colors"
              placeholder="Zde napište krátkou odpověď..."
            />
          </div>

          <div>
            <label for={`textarea-${q.id}`} class="block text-sm font-medium text-gray-700 dark:text-gray-400 mb-2">
              {q.textLabel}
            </label>
            <textarea
              id={`textarea-${q.id}`}
              name={`textarea-${q.id}`}
              rows="4"
              class="w-full px-4 py-3 bg-transparent border border-gray-300 dark:border-gray-700 rounded-md text-gray-900 dark:text-gray-100 placeholder-gray-400 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition-colors resize-y"
              placeholder="Prostor pro detailnější rozvedení myšlenky..."
            ></textarea>
          </div>
        </div>
      </fieldset>
    ))}

    <div class="pt-6">
      <button
        type="submit"
        class="w-full sm:w-auto px-8 py-3 bg-gray-900 hover:bg-gray-800 dark:bg-gray-100 dark:hover:bg-gray-200 text-white dark:text-gray-900 font-medium rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-900 dark:focus:ring-gray-100 dark:focus:ring-offset-gray-900"
      >
        Odeslat dotazník
      </button>
    </div>

  </form>
</div>
