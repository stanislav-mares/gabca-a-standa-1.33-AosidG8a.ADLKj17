---
import type { Question } from "../utils/questionnaire";
import { buildFieldMeta } from "../utils/submit-questionnaire";
import QuestionElement from "./QuestionElement.astro";

interface Props {
  questions: Question[];
  /** DOČASNÉ: zobrazí všechny otázky naráz (pro konfiguraci). */
  showAll?: boolean;
}

const { questions, showAll = false } = Astro.props;

const fieldMeta = buildFieldMeta(questions);

const buttonClass =
  "sm:w-auto px-8 py-3 bg-gray-900 hover:bg-gray-800 text-white font-medium rounded-lg transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-900";
---

<form action="#" method="POST" id="questionnaire-form" class="space-y-8">
  {
    questions.map((q, i) => (
      <fieldset
        data-step={i}
        class:list={[
          "form-step transition-all duration-1000 ease-out pb-8 border-b border-gray-200 last:border-0 last:pb-0",
          i === 0 || showAll
            ? "opacity-100 translate-y-0"
            : "hidden opacity-0 -translate-y-8",
        ]}
      >
        <legend
          class="text-xl font-semibold text-gray-900 mb-6"
          set:html={q.heading}
        />

        <div class="flex flex-col gap-6">
          {q.elements.map((el, j) => (
            <QuestionElement element={el} name={`${q.id}-e${j}`} />
          ))}
        </div>
      </fieldset>
    ))
  }

  <p
    id="form-error"
    class="hidden text-center text-red-600"
  >
    Odeslání se nepovedlo. Zkuste to prosím za chvíli znovu – odpovědi zůstaly
    vyplněné.
  </p>

  <div class="pt-6 flex justify-center">
    <button
      type="button"
      id="next-btn"
      class:list={[showAll && "hidden", buttonClass]}
    >
      Pokračovat
    </button>
    <button
      type="submit"
      id="submit-btn"
      class:list={[!showAll && "hidden", buttonClass]}
    >
      Odeslat dotazník
    </button>
  </div>
</form>

<div id="form-success" class="hidden text-center py-12">
  <p class="text-2xl font-semibold text-gray-900 mb-3">
    Děkujeme!
  </p>
  <p class="text-gray-700">
    Dotazník se odeslal a odpovědi máme uložené.
  </p>
</div>

<script
  is:inline
  type="application/json"
  id="questionnaire-meta"
  set:html={JSON.stringify(fieldMeta).replace(/</g, "\\u003c")}
/>

<script>
  import {
    submitQuestionnaire,
    type FieldMetaMap,
  } from "../utils/submit-questionnaire";

  function initQuestionnaire() {
    const form = document.getElementById(
      "questionnaire-form",
    ) as HTMLFormElement | null;
    const nextBtn = document.getElementById("next-btn");
    const submitBtn = document.getElementById(
      "submit-btn",
    ) as HTMLButtonElement | null;
    if (!form || !nextBtn || !submitBtn) return;

    const successEl = document.getElementById("form-success");
    const errorEl = document.getElementById("form-error");
    const fieldMeta = JSON.parse(
      document.getElementById("questionnaire-meta")?.textContent ?? "{}",
    ) as FieldMetaMap;

    const steps = Array.from(
      form.querySelectorAll<HTMLFieldSetElement>(".form-step"),
    );
    if (steps.length === 0) return;

    let current = 0;

    const setDisabled = (container: HTMLElement, disabled: boolean) => {
      container
        .querySelectorAll<
          HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement
        >("input, textarea, select")
        .forEach((control) => {
          control.disabled = disabled;
        });
    };

    // Rozbalí/skryje podotázky podle aktuálně vybraných odpovědí. Skryté
    // podotázky se zároveň `disable`nou, aby je nativní validace i odeslání
    // formuláře přeskočily.
    const syncFollowUps = () => {
      form
        .querySelectorAll<HTMLInputElement>("input[data-followup]")
        .forEach((trigger) => {
          const target = document.getElementById(trigger.dataset.followup!);
          if (!target) return;
          const visible = trigger.checked;
          target.classList.toggle("hidden", !visible);
          target.classList.toggle("flex", visible);
          setDisabled(target, !visible);
        });
    };

    const showStep = (step: HTMLElement) => {
      step.classList.remove("hidden");
      void step.offsetWidth; // force reflow so the transition runs
      step.classList.remove("opacity-0", "-translate-y-8");
      step.classList.add("opacity-100", "translate-y-0");
      step.scrollIntoView({ behavior: "smooth", block: "center" });
    };

    // Ověří jen viditelná pole – `disable`nuté (skryté) podotázky projdou.
    const validateStep = (step: HTMLElement) => {
      const controls = step.querySelectorAll<
        HTMLInputElement | HTMLTextAreaElement
      >("input, textarea");
      for (const control of controls) {
        if (!control.checkValidity()) {
          control.reportValidity();
          return false;
        }
      }
      return true;
    };

    const updateButtons = () => {
      const isLast = current === steps.length - 1;
      nextBtn.classList.toggle("hidden", isLast);
      submitBtn.classList.toggle("hidden", !isLast);
    };

    form.addEventListener("change", syncFollowUps);

    nextBtn.addEventListener("click", () => {
      if (!validateStep(steps[current])) return;
      if (current >= steps.length - 1) return;
      current += 1;
      showStep(steps[current]);
      updateButtons();
    });

    // Nativní validace proběhne před `submit` eventem, tady už jen odesíláme.
    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      const endpoint = import.meta.env.PUBLIC_QUESTIONNAIRE_ENDPOINT;
      if (!endpoint) {
        console.error("Chybí PUBLIC_QUESTIONNAIRE_ENDPOINT v .env");
        errorEl?.classList.remove("hidden");
        return;
      }

      errorEl?.classList.add("hidden");
      submitBtn.disabled = true;
      submitBtn.textContent = "Odesílám…";

      try {
        await submitQuestionnaire(form, fieldMeta, endpoint);
        form.classList.add("hidden");
        successEl?.classList.remove("hidden");
        successEl?.scrollIntoView({ behavior: "smooth", block: "center" });
      } catch (err) {
        console.error("Odeslání dotazníku selhalo:", err);
        errorEl?.classList.remove("hidden");
        submitBtn.disabled = false;
        submitBtn.textContent = "Odeslat dotazník";
      }
    });

    syncFollowUps(); // výchozí stav – skryté podotázky se rovnou disablují
  }

  document.addEventListener("astro:page-load", initQuestionnaire);
</script>
