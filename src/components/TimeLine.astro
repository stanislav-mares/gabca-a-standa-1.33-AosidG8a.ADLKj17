---
interface Props {
    /** Roky odpovídají id odstavců na stránce (id === rok). */
    years: string[];
}

const { years } = Astro.props;
---

<!-- Sticky kolej: drží se ve viewportu, zatímco uživatel scrolluje dlouhý text. -->
<div id="timeline" class="sticky top-0 h-screen flex justify-center pt-24">
    <div class="relative flex flex-col gap-28 self-start">
        {/* Aktivní čára – výšku řídí pozice scrollu v dokumentu. */}
        <div
            class="timeline-progress absolute left-1/2 -translate-x-1/2 top-3 w-0.5 bg-gray-800"
            style="height: 0px"
            aria-hidden="true"
        >
        </div>

        {
            years.map((year, i) => (
                <div
                    class:list={["timeline-item relative flex items-center justify-center group", { revealed: i === 0 }]}
                    data-year={year}
                >
                    <time class="absolute right-1/2 pr-8 text-heading font-light leading-none text-gray-700 group-hover:text-gray-900 group-hover:scale-110 transition-all duration-300 ease-in-out">
                        {year}
                    </time>
                    <span class="dot relative z-10 w-7 h-7 rounded-full bg-gray-800 ring-4 ring-gray-100 group-hover:scale-125 group-hover:cursor-pointer transition-all duration-300 ease-in-out" />
                </div>
            ))
        }
    </div>
</div>

<style>
    /* Výchozí (skrytý) stav každé položky. První je odhalená serverem (.revealed). */
    .timeline-item {
        opacity: 0;
        transform: translateY(0.5rem) scale(0.8);
        transition:
            opacity 0.5s ease,
            transform 0.5s ease;
    }

    .timeline-item.revealed {
        opacity: 1;
        transform: translateY(0) scale(1);
    }
</style>

<script>
    let timelineObserver: IntersectionObserver | null = null;
    let onResize: (() => void) | null = null;
    let onScroll: (() => void) | null = null;
    let scroller: HTMLElement | null = null;

    /**
     * Scrolluje se uvnitř <main> (kvůli view transitions), ne v dokumentu.
     * Najdeme nejbližšího scrollujícího předka; `null` = fallback na okno.
     */
    function getScrollParent(el: HTMLElement): HTMLElement | null {
        for (
            let node = el.parentElement;
            node && node !== document.body;
            node = node.parentElement
        ) {
            const overflowY = getComputedStyle(node).overflowY;
            if (overflowY === "auto" || overflowY === "scroll") return node;
        }
        return null;
    }

    function setupTimeline() {
        const timeline = document.getElementById("timeline");
        if (!timeline) return;

        scroller = getScrollParent(timeline);

        const items = Array.from(
            timeline.querySelectorAll<HTMLElement>(".timeline-item"),
        );
        const progress =
            timeline.querySelector<HTMLElement>(".timeline-progress");
        if (!items.length || !progress) return;

        const line = progress;
        const itemByYear = new Map(
            items.map((el) => [el.dataset.year ?? "", el]),
        );

        // Aktivní čára vyjadřuje, jak daleko je uživatel v celém dokumentu.
        function updateProgress() {
            const container = line.parentElement;
            if (!container) return;

            // Maximální délka čáry = vzdálenost k poslední kuličce.
            const lastDot =
                items[items.length - 1].querySelector<HTMLElement>(".dot");
            if (!lastDot) return;

            const containerTop = container.getBoundingClientRect().top;
            const lastRect = lastDot.getBoundingClientRect();
            // Čára startuje 12px (top-3) pod horní hranou kontejneru.
            const maxHeight = Math.max(
                0,
                lastRect.top + lastRect.height / 2 - containerTop - 12,
            );

            // Podíl odscrollování (0–1) ve scroll kontejneru, jinak v okně.
            const scrolled = scroller ? scroller.scrollTop : window.scrollY;
            const scrollable = scroller
                ? scroller.scrollHeight - scroller.clientHeight
                : document.documentElement.scrollHeight - window.innerHeight;
            const ratio = scrollable > 0 ? scrolled / scrollable : 0;
            const clamped = Math.min(1, Math.max(0, ratio));

            line.style.height = `${clamped * maxHeight}px`;
        }

        // Odhalení řídí odstavec, jehož id === rok.
        const paragraphs = items
            .map((el) => document.getElementById(el.dataset.year ?? ""))
            .filter((el): el is HTMLElement => el !== null);

        timelineObserver = new IntersectionObserver(
            (entries) => {
                for (const entry of entries) {
                    const item = itemByYear.get(entry.target.id);
                    if (!item) continue;

                    if (entry.isIntersecting) {
                        // Odstavec se dostal do záběru → kulička se objeví.
                        item.classList.add("revealed");
                    } else if (entry.boundingClientRect.top > 0) {
                        // Odstavec opustil záběr dolem (scroll nahoru) → skrýt.
                        // První kuličku necháme vždy viditelnou.
                        if (item !== items[0]) item.classList.remove("revealed");
                    }
                    // Opuštění horem (scroll dolů) kuličku ponechá odhalenou.
                }
                updateProgress();
            },
            // Spustí se, jakmile odstavec dosáhne ~60 % výšky viewportu.
            { rootMargin: "0px 0px -40% 0px", threshold: 0 },
        );

        paragraphs.forEach((p) => timelineObserver!.observe(p));

        updateProgress();

        onResize = updateProgress;
        window.addEventListener("resize", onResize);

        // Čára reaguje na scroll okamžitě (throttle přes rAF).
        let ticking = false;
        onScroll = () => {
            if (ticking) return;
            ticking = true;
            requestAnimationFrame(() => {
                updateProgress();
                ticking = false;
            });
        };
        (scroller ?? window).addEventListener("scroll", onScroll, {
            passive: true,
        });
    }

    function teardownTimeline() {
        timelineObserver?.disconnect();
        timelineObserver = null;
        if (onResize) window.removeEventListener("resize", onResize);
        onResize = null;
        if (onScroll) (scroller ?? window).removeEventListener("scroll", onScroll);
        onScroll = null;
        scroller = null;
    }

    document.addEventListener("astro:page-load", setupTimeline);
    document.addEventListener("astro:before-swap", teardownTimeline);
</script>
