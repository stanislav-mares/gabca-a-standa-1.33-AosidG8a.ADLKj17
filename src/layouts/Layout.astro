---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import mainPhoto from "../assets/dkr-1795.jpg";
---

<!doctype html>
<html lang="cs">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="generator" content={Astro.generator} />
        <title>S & G</title>

        <ClientRouter />
    </head>
    <body class="text-black text">
        <!-- Fotka pozadí mimo <main>: neúčastní se slide přechodu a prosvítá
             skrz průhledné panely podstránek -->
        <div class="fixed flex -z-10 overflow-hidden inset-0 w-full h-full">
            <div class="flex-1">
                <img
                    src={mainPhoto.src}
                    alt=""
                    class="w-full h-full object-cover scale-130 origin-[0%_50%]"
                />
            </div>
        </div>
        <slot />
    </body>
</html>
