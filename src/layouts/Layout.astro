---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import { Image } from "astro:assets";
import mainPhoto from "../assets/dkr-1795.jpg";
---

<!doctype html>
<html lang="cs">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
        <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />
        <meta name="generator" content={Astro.generator} />
        <title>S & G</title>

        <!-- Blokující skript: označ html třídou ještě před prvním paintem,
             aby po refreshi neprobliklo intro (CSS pak rovnou ukáže header) -->
        <script is:inline>
            if (sessionStorage.getItem("intro-seen")) {
                document.documentElement.classList.add("intro-seen");
            }
        </script>

        <ClientRouter />
    </head>
    <body class="text-black text">
        <!-- Fotka pozadí mimo <main>: neúčastní se slide přechodu a prosvítá
             skrz průhledné panely podstránek -->
        <div class="fixed flex -z-10 overflow-hidden inset-0 w-full h-full">
            <div class="flex-1">
                <Image
                    src={mainPhoto}
                    alt=""
                    widths={[768, 1280, 1920, 2799]}
                    sizes="100vw"
                    format="webp"
                    loading="eager"
                    class="w-full h-full object-cover scale-130 origin-[0%_50%]"
                />
            </div>
        </div>
        <slot />
    </body>
</html>
