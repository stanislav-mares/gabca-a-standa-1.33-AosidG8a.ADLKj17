---
import Layout from "../layouts/Layout.astro";
import BackButton from "../components/BackButton.astro";
import Questionnaire from "../components/Questionnaire.astro";
import type { Question } from "../utils/questionnaire";
import { slideTransition } from "../utils/transitions";

const heading = "Dotazník";
const intro = "Poprosíme vás o vyplnění krátkého dotazníku. Moc nám to pomůže s další organizací a přípravami, abychom tak mohli strávit příjemný čas spolu ke spokojenosti všech. Pokud vás napadne něco dalšího, co není v otázkách, napište nám to prosím do posledního formuláře níže. Děkujeme :)";

// Ukázková konfigurace – uprav si otázky i prvky přímo tady.
const questions: Question[] = [
    {
        id: "ucast",
        heading: "",
        elements: [
            {
                type: "short-text",
                label: "Jméno a příjmení",
                description: "Pokud vyplňuješ za více lidí, uveď prosím všechny, oddělené čárkou.",
                placeholder: "Jan Novák",
                required: true,
            },
        ],
    },
    {
        id: "arrival",
        heading: "",
        elements: [
            {
                type: "yes-no",
                label: "Dorazíš na svatbu?",
                description: "Prosíme o potvrzení účasti nejpozději do konce srpna.",
                required: true,
                options: [
                    {
                        value: "ano",
                        label: "Ano",
                    },
                    { value: "ne", label: "Bohužel nemohu", followUp: {
                        heading: "Nevadí, děkujeme za vyplnění.",
                        elements: [],
                    },},
                ],
            },
        ],
    },

    {
        id: "prijezd",
        heading: "",
        elements: [
            {
                type: "single-choice",
                label: "Kdy přijedeš?",
                required: true,
                options: [
                    {
                        value: "svatba",
                        label: "V den svatby",
                        followUp: {
                            heading: `Příjezd cca mezi 10:30 - 11:00. Více informací naleznete zde: <a href="/svatebni-den" class="underline text-black">zde</a>`,
                            elements: [],
                        },
                    },
                    {
                        value: "patek",
                        label: "V pátek",
                        followUp: {
                            heading: "Budeme rádi za pomoc s přípravami. Jídlo, pití a spaní zajištěno.",
                            elements: [],
                        },
                    },
                ],
            },
        ],
    },

    {
        id: "sleep",
        heading: "",
        elements: [
            {
                type: "yes-no",
                label: "Budeš chtít přespat přímo na místě nebo v blízkém okolí?",
                description: `Ubytování jsme schopni zajistit pro všechny hosty. Bližší informace k ubytování budou zavčasu zveřejněny
                <a href="/ubytovani" class="underline text-black">zde</a>`,
                required: true,
                options: [
                    {
                        value: "ano",
                        label: "Ano",
                        followUp: {
                            heading: "",
                            elements: [
                                {
                                    type: "multi-choice",
                                    label: "",
                                    description: "",
                                    required: true,
                                    options: [
                                        {
                                            value: "misto",
                                            label: "Preferuji přespat přímo v místě.",
                                        },
                                        {
                                            value: "okoli",
                                            label: "Preferuji přespat v blízkém okolí (do 10km, odvoz zajištěn)",
                                        },
                                        {
                                            value: "vlastni",
                                            label: "Vezmu si vlastní stan, obytňák, ...",
                                        },
                                    ],
                                },
                            ],
                        },
                    },
                    {
                        value: "ne",
                        label: "Ne",
                        followUp: {
                            heading: "Pojedu vlastním autem domů.",
                            elements: [],
                        },
                    },
                ],
            },
        ],
    },
    {
        id: "strava",
        heading: "",
        elements: [
            {
                type: "multi-choice",
                label: "Stravovací omezení",
                description:
                    "Zaškrtni vše, co se vás týká. U každé možnosti prosím napiš, koho konkrétně.",
                options: [
                    {
                        value: "vegan",
                        label: "Vegan",
                        followUp: {
                            elements: [
                                {
                                    type: "short-text",
                                    label: "",
                                    placeholder: "Koho se týká? Jména oddělte čárkou.",
                                },
                            ],
                        },
                    },
                    {
                        value: "vegetarian",
                        label: "Vegetarián",
                        followUp: {
                            elements: [
                                {
                                    type: "short-text",
                                    label: "",
                                    placeholder: "Koho se týká? Jména oddělte čárkou.",
                                },
                            ],
                        },
                    },
                    {
                        value: "bezlepkova",
                        label: "Bezlepková dieta",
                        followUp: {
                            elements: [
                                {
                                    type: "short-text",
                                    label: "",
                                    placeholder: "Koho se týká? Jména oddělte čárkou.",
                                },
                            ],
                        },
                    },
                    {
                        value: "alergie",
                        label: "Alergie",
                        followUp: {
                            elements: [
                                {
                                    type: "short-text",
                                    label: "",
                                    placeholder: "Jaké alergie (ořechy, laktóza, …) a koho se týká? Jména oddělte čárkou.",
                                },
                            ],
                        },
                    },
                    {
                        value: "jine",
                        label: "Jiné",
                        followUp: {
                            elements: [
                                {
                                    type: "textarea",
                                    label: "",
                                    placeholder:
                                        "Jaké omezení a koho se týká? Jména oddělte čárkou.",
                                },
                            ],
                        },
                    },
                ],
            },
        ],
    },
    {
        id: "piti-nealko",
        heading: "",
        elements: [
            {
                type: "multi-choice",
                label: "Co by sis dal k pití: nealko?",
                options: [
                    { value: "perliva-voda", label: "Perlivá voda" },
                    { value: "dzus", label: "Džus" },
                    { value: "kofola", label: "Kofola" },
                    { value: "coca-cola", label: "Coca-Cola" },
                    { value: "tonic", label: "Tonic" },
                    {
                        value: "birell",
                        label: "Birell",
                        followUp: {
                            elements: [
                                {
                                    type: "single-choice",
                                    label: "",
                                    options: [
                                        { value: "ochuceny", label: "Ochucený" },
                                        {
                                            value: "neochuceny",
                                            label: "Neochucený",
                                        },
                                    ],
                                },
                            ],
                        },
                    },
                    { value: "limonada", label: "Domácí limonáda" },
                    {
                        value: "jine",
                        label: "Jiné",
                        followUp: {
                            elements: [
                                {
                                    type: "short-text",
                                    label: "",
                                    placeholder: "Co jiného?",
                                },
                            ],
                        },
                    },
                ],
            },
        ],
    },
    {
        id: "piti-alko",
        heading: "",
        elements: [
            {
                type: "multi-choice",
                label: "Co by sis dal k pití: alko?",
                options: [
                    { value: "pivo", label: "Pivo" },
                    { value: "vino", label: "Víno" },
                    { value: "sampus", label: "Šampus" },
                    { value: "gin-tonic", label: "Gin-tonic" },
                    { value: "aperol", label: "Aperol" },
                    { value: "rum-cola", label: "Rum s colou" },
                    {
                        value: "jine",
                        label: "Jiné",
                        followUp: {
                            elements: [
                                {
                                    type: "short-text",
                                    label: "",
                                    placeholder: "Co jiného?",
                                },
                            ],
                        },
                    },
                ],
            },
        ],
    },
    {
        id: "piti-alko-plus",
        heading: "",
        elements: [
            {
                type: "multi-choice",
                label: "Co by sis dal k pití: alko+?",
                options: [
                    { value: "slivovice", label: "Slivovice" },
                    { value: "mandlovice", label: "Mandlovice" },
                    { value: "rum", label: "Rum" },
                    { value: "whiskey", label: "Whiskey" },
                    { value: "becherovka", label: "Becherovka" },
                    { value: "jagermeister", label: "Jägermeister" },
                    {
                        value: "jine",
                        label: "Jiné",
                        followUp: {
                            elements: [
                                {
                                    type: "short-text",
                                    label: "",
                                    placeholder: "Co jiného?",
                                },
                            ],
                        },
                    },
                ],
            },
        ],
    },
    {
        id: "poznamka",
        heading: "",
        elements: [
            {
                type: "textarea",
                label: "Napadá tě ještě něco dalšího?",
                placeholder: "Cokoli, co bychom měli vědět…",
            },
        ],
    },
];
---

<Layout>
    <main
        class="h-screen w-full pt-15 bg-surface/95 overflow-y-auto"
        transition:animate={slideTransition}
        transition:name="main-panel"
    >
        <section class="flex flex-col items-center px-6 sm:px-10">
            <h1 class="text-title font-light mb-8" data-reveal>{heading}</h1>
            <div class="w-full max-w-3xl">
                <p
                    class="text-lg leading-relaxed text-justify"
                    data-reveal
                    style="--reveal-delay: 0.35s"
                >
                    {intro}
                </p>
                <div class="pt-10 pb-[50vh]" data-reveal style="--reveal-delay: 0.5s">
                    <Questionnaire questions={questions} showAll />
                </div>
            </div>
        </section>

        <aside class="fixed top-0 left-0 flex justify-center items-center h-full">
            <BackButton />
        </aside>
    </main>
</Layout>
