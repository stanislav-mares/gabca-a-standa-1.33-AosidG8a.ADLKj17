---
import Layout from "../layouts/Layout.astro";
import BackButton from "../components/BackButton.astro";
import { slideTransition } from "../utils/transitions";

const heading = "Svatební den";
const textContent = [
    { time: "8:00", content: "Snídaně" },
    { time: "10:30", content: "Příjezd hostů" },
    { time: "12:00", content: "Obřad" },
    { time: "13:00", content: "Gratulace a focení" },
    { time: "14:00", content: "Oběd" },
    { time: "16:00", content: "Krájení dortu" },
    { time: "19:00", content: "První tanec" },
    { time: "20:00", content: "Večerní zábava" },
];
---

<Layout>
    <main
        class="h-screen w-full pt-16 bg-surface/95 overflow-y-auto"
        transition:animate={slideTransition}
        transition:name="main-panel"
    >
        <section class="flex flex-col items-center justify-center px-6 sm:px-10">
            <h1 class="font-heading text-heading tracking-wider" data-reveal>{heading}</h1>
            <article class="flex flex-col gap-6 w-full pt-20 pb-[50vh]">
                {
                    textContent.map((item, i) => (
                        <>
                        {i > 0 && (
                            <div class="mx-auto w-px h-12 bg-ink/20" aria-hidden="true" />
                        )}
                        <div
                            id={item.time.replace(":", "-")}
                            data-story-section
                            class="scroll-mt-24 md:grid md:grid-cols-[1fr_minmax(0,48rem)_1fr] md:gap-x-24"
                            data-reveal
                            style={`--reveal-delay: ${0.3 + i * 0.12}s`}
                        >
                            <h2
                                class:list={[
                                    "story-year font-heading text-7xl md:text-8xl mb-5 md:mb-0",
                                    "text-ink/25 transition-colors duration-500",
                                    "md:row-start-1 md:self-center",
                                    i % 2 === 0
                                        ? "md:col-start-1 md:text-right"
                                        : "md:col-start-3 md:text-left",
                                ]}
                            >
                                {item.time}
                            </h2>
                            <h3 class="story-title font-heading text-5xl md:text-7xl py-4 md:py-6 text-center md:col-start-2 md:row-start-1 md:self-center text-ink/25 transition-colors duration-500">
                                {item.content}
                            </h3>
                        </div>
                        </>
                    ))
                }
            </article>
        </section>
        <aside class="fixed top-0 left-0 flex justify-center items-center h-full">
            <BackButton />
        </aside>
    </main>
</Layout>

<script>
    let cleanup: (() => void) | undefined;

    function initStoryTimes() {
        cleanup?.();
        cleanup = undefined;

        const main = document.querySelector("main");
        const sections = Array.from(
            document.querySelectorAll<HTMLElement>("[data-story-section]"),
        );
        if (!main || sections.length === 0) return;

        const setActive = (active: HTMLElement) => {
            for (const section of sections) {
                const parts = section.querySelectorAll(".story-year, .story-title");
                for (const part of parts) {
                    part.classList.toggle("text-ink", section === active);
                    part.classList.toggle("text-ink/25", section !== active);
                }
            }
        };

        // Svítí sekce, jejíž střed je nejblíž polovině obrazovky — každá
        // tak dostane stejně dlouhý úsek scrollu. U horního okraje vždy první.
        let ticking = false;
        const update = () => {
            ticking = false;
            const line = window.innerHeight / 2;
            let active = sections[0];
            if (main.scrollTop > 0) {
                let best = Infinity;
                for (const section of sections) {
                    const rect = section.getBoundingClientRect();
                    const distance = Math.abs(rect.top + rect.height / 2 - line);
                    if (distance < best) {
                        best = distance;
                        active = section;
                    }
                }
            }
            setActive(active);
        };
        const onScroll = () => {
            if (!ticking) {
                ticking = true;
                requestAnimationFrame(update);
            }
        };

        main.addEventListener("scroll", onScroll, { passive: true });
        update();
        cleanup = () => main.removeEventListener("scroll", onScroll);
    }

    document.addEventListener("astro:page-load", initStoryTimes);
</script>
