---
import Layout from "../layouts/Layout.astro";
import BackButton from "../components/BackButton.astro";
import { slideTransition } from "../utils/transitions";

const heading = "Svatební den";
const textContent = [
    { time: "8:00", content: "Snídaně", description: "Společně si dáme klidnou snídani, než den naplno začne." },
    { time: "10:30", content: "Příjezd hostů", description: "Hosté postupně dorazí a usadí se na svá místa." },
    { time: "12:00", content: "Obřad", description: "Řekneme si své ANO před rodinou a přáteli." },
    { time: "13:00", content: "Gratulace a focení", description: "Prostor na gratulace, přípitek a společné fotografie." },
    { time: "14:00", content: "Oběd", description: "Usedneme ke společnému obědu a odpočineme si." },
    { time: "16:00", content: "Krájení dortu", description: "Nakrojíme svatební dort a rozdáme první kousky." },
    { time: "19:00", content: "První tanec", description: "Otevřeme parket naším prvním společným tancem." },
    { time: "20:00", content: "Večerní zábava", description: "Večer si užijeme hudbu, tanec a dobrou náladu." },
];
---

<Layout>
    <main
        class="h-screen w-full pt-16 bg-surface/95 overflow-y-auto"
        transition:animate={slideTransition}
        transition:name="main-panel"
    >
        <section class="flex flex-col items-center justify-center px-6 sm:px-10">
            <h1 class="font-heading text-heading tracking-wider" data-reveal>{heading}</h1>
            <article class="flex flex-col gap-14 w-full pt-20 pb-[50vh]">
                {
                    textContent.map((item, i) => (
                        <div
                            id={item.time.replace(":", "-")}
                            data-story-section
                            class="scroll-mt-24 w-full max-w-3xl mx-auto 2xl:max-w-none 2xl:grid 2xl:grid-cols-[1fr_minmax(0,48rem)_1fr] 2xl:gap-x-24 2xl:gap-y-2"
                            data-reveal
                            style={`--reveal-delay: ${0.3 + i * 0.12}s`}
                        >
                            <div class="flex items-baseline justify-start gap-x-4 2xl:contents">
                                <h2
                                    class:list={[
                                        "story-year font-heading text-6xl 2xl:text-8xl",
                                        "text-ink/25 transition-colors duration-500",
                                        "2xl:row-start-1 2xl:self-center",
                                        i % 2 === 0
                                            ? "2xl:col-start-1 2xl:text-right"
                                            : "2xl:col-start-3 2xl:text-left",
                                    ]}
                                >
                                    {item.time}
                                </h2>
                                <h3 class="story-title font-heading text-4xl 2xl:text-7xl 2xl:py-6 text-left 2xl:text-center 2xl:col-start-2 2xl:row-start-1 2xl:self-center text-ink/25 transition-colors duration-500">
                                    {item.content}
                                </h3>
                            </div>
                            <p class="mt-1 text-paragraph text-left text-ink/50 2xl:mt-0 2xl:col-start-2 2xl:row-start-2 2xl:text-center">
                                {item.description}
                            </p>
                        </div>
                    ))
                }
            </article>
        </section>
        <BackButton />
    </main>
</Layout>

<script>
    let cleanup: (() => void) | undefined;

    function initStoryTimes() {
        cleanup?.();
        cleanup = undefined;

        const main = document.querySelector("main");
        const sections = Array.from(
            document.querySelectorAll<HTMLElement>("[data-story-section]"),
        );
        if (!main || sections.length === 0) return;

        const setActive = (active: HTMLElement) => {
            for (const section of sections) {
                const parts = section.querySelectorAll(".story-year, .story-title");
                for (const part of parts) {
                    part.classList.toggle("text-ink", section === active);
                    part.classList.toggle("text-ink/25", section !== active);
                }
            }
        };

        // Svítí sekce, jejíž střed je nejblíž polovině obrazovky — každá
        // tak dostane stejně dlouhý úsek scrollu. U horního okraje vždy první.
        let ticking = false;
        const update = () => {
            ticking = false;
            const line = window.innerHeight / 2;
            let active = sections[0];
            if (main.scrollTop > 0) {
                let best = Infinity;
                for (const section of sections) {
                    const rect = section.getBoundingClientRect();
                    const distance = Math.abs(rect.top + rect.height / 2 - line);
                    if (distance < best) {
                        best = distance;
                        active = section;
                    }
                }
            }
            setActive(active);
        };
        const onScroll = () => {
            if (!ticking) {
                ticking = true;
                requestAnimationFrame(update);
            }
        };

        main.addEventListener("scroll", onScroll, { passive: true });
        update();
        cleanup = () => main.removeEventListener("scroll", onScroll);
    }

    document.addEventListener("astro:page-load", initStoryTimes);
</script>
