---
import Layout from "../layouts/Layout.astro";
import BackButton from "../components/BackButton.astro";
import { slideTransition } from "../utils/transitions";

const heading = "Ubytování";
---

<Layout>
    <main
        class="h-screen w-full pt-15 bg-gray-50 overflow-y-auto"
        transition:animate={slideTransition}
        transition:name="main-panel"
    >
        <section class="flex flex-col items-center justify-center">
            <h1 class="text-title font-light mb-8">{heading}</h1>
        </section>
        <aside class="fixed top-0 left-0 flex justify-center items-center h-full">
            <BackButton />
        </aside>
    </main>
</Layout>
